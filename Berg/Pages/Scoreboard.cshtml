@page
@using Berg.Db
@model Berg.Pages.Scoreboard

@{
    ViewData["Title"] = $"{Model.SelectedCategory} Scoreboard";
}

<h3>Scoreboard</h3>

<ul class="nav nav-tabs">
    @foreach (var category in Enum.GetValues<Category>())
    {
        if (category == Model.SelectedCategory) 
        {
            <li class="nav-item">
                <a class="nav-link active" href="/scoreboard?category=@category">
                    @category
                    @if (Model.PlayerCategory == category)
                    {
                        <span class="badge bg-info">you</span>
                    }
                </a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href="/scoreboard?category=@category">
                    @category
                    @if (Model.PlayerCategory == category)
                    {
                        <span class="badge bg-info">you</span>
                    }
                </a>
            </li>
        }
    }
    <li class="nav-item">
        @if (Model.SelectedCategory == null)
        {
            <a class="nav-link active" href="/scoreboard?category=Combined">
                Combined
            </a>
        }
        else
        {
            <a class="nav-link" href="/scoreboard?category=Combined">
                Combined
            </a>
        }
    </li>
</ul>

<table class="table table-striped">
    <thead>
    <tr>
        <th scope="col">#</th>
        <th scope="col">Name</th>
        @if (Model.SelectedCategory == null)
        {
            <th scope="col">Category</th>
        }
        <th scope="col">Score</th>
        <th scope="col">Last solve (UTC)</th>
        <th scope="col">Solved challenges</th>
    </tr>
    </thead>
    <tbody class="table-group-divider">
    @{ var rank = 1;}
    @foreach (var entry in Model.ScoreboardEntries)
    {
        var avatarUrl = $"https://cdn.discordapp.com/avatars/{entry.DiscordId}/{entry.DiscordAvatarId}.png?size=32";
        if (entry.DiscordAvatarId == null)
        {
            avatarUrl = "https://cdn.discordapp.com/embed/avatars/1.png?size=32";
        }
        <tr>
            <th scope="row">@rank</th>
            <td>
                <img src="@avatarUrl" alt="Avatar" width="20px" height="20px">
                @entry.PlayerName
                @if (Model.DiscordId == entry.DiscordId)
                {
                    <span class="badge bg-info">you</span>
                }
            </td>
            @if (Model.SelectedCategory == null)
            {
                <td>@entry.PlayerCategory</td>
            }
            <td>@entry.Score</td>
            <td>@entry.LastSolveAt</td>
            <td>
                @if (Model.CtfInfo.CtfStart < DateTime.Now)
                {
                    foreach (var challenge in Model.CtfInfo.Challenges)
                    {
                        if (entry.SolvedChallenges.Contains(challenge.Id))
                        {
                            if (entry.FirstBloodedChallenges.Contains(challenge.Id) && Model.SelectedCategory != null)
                            {
                                <i class="bi bi-droplet-fill text-danger" data-bs-toggle="tooltip" data-bs-title="@challenge.Name"></i>
                            }
                            else
                            {
                                <i class="bi bi-pentagon-fill text-primary" data-bs-toggle="tooltip" data-bs-title="@challenge.Name"></i>
                            }
                        }
                        else
                        {
                            <i class="bi bi-pentagon text-secondary" data-bs-toggle="tooltip" data-bs-title="@challenge.Name"></i>
                        }
                    }
                }
            </td>
        </tr>
        rank++;
    }
    </tbody>
</table>
